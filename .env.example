# Football-Data.org API Key (免费注册: https://www.football-data.org/client/register)
FOOTBALL_API_KEY=your_api_key_here

# 关注的联赛ID (逗号分隔)
# 2021 = Premier League, 2002 = Bundesliga, 2014 = La Liga
# 2003 = Eredivisie, 2015 = Ligue 1, 2019 = Serie A
LEAGUE_IDS=2021,2002,2014,2019,2015

# 数据库路径
DATABASE_URL=sqlite:///data/football.db
